{
    "workbench.colorTheme": "Light Modern",
    "workbench.colorCustomizations": {
        "editor.background": "#FFFFF0",
        "editor.foreground": "#424242",
        "editor.selectionBackground": "#EEEEA7",
        "editor.lineHighlightBackground": "#FFFFF0",
        "editor.findMatchBackground": "#EEEEA7",
        "editor.findMatchHighlightBackground": "#E2F1F8",
        "editorCursor.foreground": "#424242",
        "editorLineNumber.foreground": "#999957",
        "editorLineNumber.activeForeground": "#424242",
        "editorGutter.background": "#EAEBDB",
        "sideBar.background": "#EAEBDB",
        "sideBar.foreground": "#424242",
        "sideBarTitle.foreground": "#424242",
        "activityBar.background": "#EAEBDB",
        "activityBar.foreground": "#424242",
        "statusBar.background": "#EAEBDB",
        "statusBar.foreground": "#424242",
        "titleBar.activeBackground": "#EAEBDB",
        "titleBar.activeForeground": "#424242",
        "tab.activeBackground": "#FFFFF0",
        "tab.inactiveBackground": "#EAEBDB",
        "tab.activeForeground": "#424242",
        "tab.inactiveForeground": "#999957",
        "panel.background": "#FFFFF0",
        "panel.border": "#EAEBDB",
        "terminal.background": "#FFFFF0",
        "terminal.foreground": "#424242",
        "terminal.ansiBlack": "#424242",
        "terminal.ansiRed": "#B85C57",
        "terminal.ansiGreen": "#57864E",
        "terminal.ansiYellow": "#8F7634",
        "terminal.ansiBlue": "#2A8DC5",
        "terminal.ansiMagenta": "#8888C7",
        "terminal.ansiCyan": "#6AA7A8",
        "terminal.ansiWhite": "#EAEBDB",
        "terminal.ansiBrightBlack": "#999957",
        "terminal.ansiBrightRed": "#F2ACAA",
        "terminal.ansiBrightGreen": "#98CE8F",
        "terminal.ansiBrightYellow": "#B7B19C",
        "terminal.ansiBrightBlue": "#A6DCF8",
        "terminal.ansiBrightMagenta": "#D0D0F7",
        "terminal.ansiBrightCyan": "#B0ECED",
        "terminal.ansiBrightWhite": "#FFFFF0",
        "diffEditor.insertedTextBackground": "#EFFEEC",
        "diffEditor.removedTextBackground": "#F8E7E7",
        "editorError.foreground": "#B85C57",
        "editorWarning.foreground": "#8F7634",
        "editorInfo.foreground": "#2A8DC5",
        "list.activeSelectionBackground": "#EEEEA7",
        "list.activeSelectionForeground": "#424242",
        "list.hoverBackground": "#EAEBDB",
        "input.background": "#FFFFF0",
        "input.border": "#B7B19C",
        "focusBorder": "#2A8DC5",
        "editorGroup.border": "#EAEBDB",
        "editorBracketHighlight.foreground1": "#424242",
        "editorBracketHighlight.foreground2": "#424242",
        "editorBracketHighlight.foreground3": "#424242",
        "editorBracketHighlight.foreground4": "#424242",
        "editorBracketHighlight.foreground5": "#424242",
        "editorBracketHighlight.foreground6": "#424242",
        "editorBracketPairGuide.activeBackground1": "#B7B19C",
        "editorBracketPairGuide.activeBackground2": "#B7B19C"
    },
    "editor.tokenColorCustomizations": {
        "comments": {
            "foreground": "#57864E",
            "fontStyle": "italic"
        },
        "keywords": {
            "fontStyle": "bold"
        },
        "strings": {
            "fontStyle": "italic"
        },
        "textMateRules": [
            {
                "scope": [
                    "entity.name.function",
                    "entity.name.type",
                    "entity.other.attribute-name",
                    "entity.other.inherited-class",
                    "support.type",
                    "support.class",
                    "support.function",
                    "support.constant",
                    "variable",
                    "variable.other",
                    "variable.parameter",
                    "constant.numeric",
                    "constant.language",
                    "constant.character",
                    "constant.other",
                    "variable.other.constant",
                    "variable.other.readwrite",
                    "variable.other.object",
                    "meta.function-call",
                    "meta.object-literal.key",
                    "punctuation",
                    "keyword.operator",
                    "keyword.operator.new",
                    "keyword.operator.expression",
                    "punctuation.definition.template-expression",
                    "punctuation.definition.template-expression.begin",
                    "punctuation.definition.template-expression.end",
                    "punctuation.section.embedded",
                    "meta.template.expression",
                    "markup"
                ],
                "settings": { "foreground": "#424242", "fontStyle": "" }
            },
            {
                "scope": [
                    "storage.type",
                    "storage.modifier",
                    "keyword",
                    "keyword.control",
                    "keyword.control.flow",
                    "keyword.operator.new",
                    "keyword.operator.expression.of",
                    "keyword.operator.expression.in",
                    "keyword.operator.expression.typeof",
                    "keyword.operator.expression.instanceof"
                ],
                "settings": { "foreground": "#424242", "fontStyle": "bold" }
            },
            {
                "scope": ["string", "string.quoted"],
                "settings": { "foreground": "#424242", "fontStyle": "italic" }
            },
            {
                "scope": ["comment", "punctuation.definition.comment"],
                "settings": { "foreground": "#57864E", "fontStyle": "italic" }
            }
        ]
    },
    "editor.fontFamily": "JetBrains Mono",
    "editor.fontSize": 15,
    "editor.fontLigatures": true,
    "editor.semanticHighlighting.enabled": false
}
